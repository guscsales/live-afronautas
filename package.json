{
  "name": "live-afronautas-crud",
  "version": "1.0.0",
  "description": "CRUD de usuários para teste com cliente",
  "main": "src/server.ts",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "bun build src/server.ts --outdir=dist --target=bun",
    "start": "bun dist/server.js",
